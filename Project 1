# pages/login_page.py
from selenium.webdriver.common.by import By

class LoginPage:
    EMAIL = (By.ID, "email")
    PASSWORD = (By.ID, "password")
    LOGIN_BTN = (By.XPATH, "//button[text()='Login']")
    ERROR_MSG = (By.CLASS_NAME, "error-message")
    DASHBOARD = (By.ID, "dashboard")

    def __init__(self, driver):
        self.driver = driver

    def open(self):
        self.driver.get("https://www.guvi.in/login")

    def enter_email(self, email):
        self.driver.find_element(*self.EMAIL).send_keys(email)

    def enter_password(self, password):
        self.driver.find_element(*self.PASSWORD).send_keys(password)

    def click_login(self):
        self.driver.find_element(*self.LOGIN_BTN).click()

    def is_error_message_displayed(self):
        return self.driver.find_element(*self.ERROR_MSG).is_displayed()

    def is_dashboard_loaded(self):
        return self.driver.find_element(*self.DASHBOARD).is_displayed()
