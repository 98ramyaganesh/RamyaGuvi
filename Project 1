    def test_url_is_valid(self):
        self.driver.get("https://www.guvi.in")
        assert "guvi.in" in self.driver.current_url

    def test_title_is_correct(self):
        self.driver.get("https://www.guvi.in")
        assert self.driver.title == "GUVI | Learn to code in your native language"

    def test_login_button(self):
        home = HomePage(self.driver)
        assert home.is_login_button_visible()
        home.click_login_button()
        assert "login" in self.driver.current_url
3 Login and sign up
# pages/homepage.py
from selenium.webdriver.common.by import By

class HomePage:
    LOGIN_BTN = (By.XPATH, "//a[text()='Login']")
    SIGNUP_BTN = (By.XPATH, "//a[text()='Sign Up']")

    def __init__(self, driver):
        self.driver = driver

    def is_login_button_visible(self):
        return self.driver.find_element(*self.LOGIN_BTN).is_displayed()

    def click_login_button(self):
        self.driver.find_element(*self.LOGIN_BTN).click()

    def is_signup_button_visible(self):
        return self.driver.find_element(*self.SIGNUP_BTN).is_displayed()

    def click_signup_button(self):
        self.driver.find_element(*self.SIGNUP_BTN).click()
