def test_create_new_user(driver):
    # Login as Admin
    driver.get("https://opensource-demo.orangehrmlive.com/")
    driver.find_element_by_id("txtUsername").send_keys("Admin")
    driver.find_element_by_id("txtPassword").send_keys("admin123")
    driver.find_element_by_id("btnLogin").click()

    # Navigate to Admin > User Management
    driver.find_element_by_link_text("Admin").click()
    driver.find_element_by_id("btnAdd").click()
    driver.find_element_by_id("systemUser_employeeName_empName").send_keys("Linda Anderson")
    driver.find_element_by_id("systemUser_userName").send_keys("newuser123")
    driver.find_element_by_id("systemUser_password").send_keys("Password123!")
    driver.find_element_by_id("systemUser_confirmPassword").send_keys("Password123!")
    driver.find_element_by_id("btnSave").click()

    # Logout and login with new user
    driver.find_element_by_id("welcome").click()
    driver.find_element_by_link_text("Logout").click()
    driver.find_element_by_id("txtUsername").send_keys("newuser123")
    driver.find_element_by_id("txtPassword").send_keys("Password123!")
    driver.find_element_by_id("btnLogin").click()
    assert "dashboard" in driver.current_url

