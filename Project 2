Feature: Login functionality

  Scenario Outline: Validate login with multiple credentials
    Given I open the OrangeHRM login page
    When I login with username "<username>" and password "<password>"
    Then I should see "<expected_result>"

    Examples:
      | username       | password     | expected_result |
      | Admin          | admin123     | success         |
      | invalid_user   | wrong_pass   | failure         |

from behave import given, when, then
from pages.login_page import LoginPage

@given("I open the OrangeHRM login page")
def step_open_login(context):
    context.login_page = LoginPage(context.driver)
    context.login_page.open()

@when('I login with username "{username}" and password "{password}"')
def step_login(context, username, password):
    context.login_page.login(username, password)

@then('I should see "{expected_result}"')
def step_validate_login(context, expected_result):
    if expected_result == "success":
        assert context.login_page.is_dashboard_visible()
    else:
        assert context.login_page.is_error_message_visible()
from selenium.webdriver.common.by import By

class LoginPage:
    def __init__(self, driver):
        self.driver = driver
        self.url = "https://opensource-demo.orangehrmlive.com/"
        self.username_field = (By.ID, "txtUsername")
        self.password_field = (By.ID, "txtPassword")
        self.login_button = (By.ID, "btnLogin")
        self.error_message = (By.ID, "spanMessage")

    def open(self):
        self.driver.get(self.url)

    def login(self, username, password):
        self.driver.find_element(*self.username_field).send_keys(username)
        self.driver.find_element(*self.password_field).send_keys(password)
        self.driver.find_element(*self.login_button).click()

    def is_dashboard_visible(self):
        return "dashboard" in self.driver.current_url.lower()

    def is_error_message_visible(self):
        return self.driver.find_element(*self.error_message).is_displayed()
