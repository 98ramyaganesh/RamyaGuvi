import pytest
from pages.login_page import LoginPage
from utils.data_loader import get_login_data

def test_homepage_accessible(driver):
    login_page = LoginPage(driver)
    login_page.open()
    assert "OrangeHRM" in driver.title

def test_login_fields_visible(driver):
    login_page = LoginPage(driver)
    login_page.open()
    assert driver.find_element(*LoginPage.USERNAME).is_displayed()
    assert driver.find_element(*LoginPage.PASSWORD).is_displayed()

@pytest.mark.parametrize("username,password,expected", get_login_data())
def test_login_with_multiple_credentials(driver, username, password, expected):
    login_page = LoginPage(driver)
    login_page.open()
    login_page.login(username, password)
    if expected == "success":
        assert login_page.is_logged_in()
    else:
        assert login_page.is_error_displayed()

def test_forgot_password(driver):
    login_page = LoginPage(driver)
    login_page.open()
    login_page.click_forgot_password()
    assert "requestPasswordResetCode" in driver.current_url
