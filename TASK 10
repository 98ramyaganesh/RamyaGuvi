3.URL OF DASHBOARD USING GIEN CREDENTIALS
import pytest
from selenium import webdriver
from selenium.webdriver.common.by import By
from selenium.webdriver.chrome.service import Service
import time

@pytest.fixture(scope="module")
def driver():
    # Path to your ChromeDriver (update this path if needed)
    service = Service("path/to/chromedriver")
    driver = webdriver.Chrome(service=service)
    driver.get("https://www.saucedemo.com/")
    yield driver
    driver.quit()

def test_dashboard_url_after_login(driver):
    """Positive test case: Verify dashboard URL after login"""
    # Enter username
    driver.find_element(By.ID, "user-name").send_keys("standard_user")
    # Enter password
    driver.find_element(By.ID, "password").send_keys("secret_sauce")
    # Click login
    driver.find_element(By.ID, "login-button").click()

    time.sleep(2)  # wait for redirect

    # Assert that the current URL is the inventory dashboard
    assert driver.current_url == "https://www.saucedemo.com/inventory.html", \
        f"Expected dashboard URL 'https://www.saucedemo.com/inventory.html' but got {driver.current_url}"

def test_dashboard_url_negative(driver):
    """Negative test case: URL should not be the login page after successful login"""
    assert driver.current_url != "https://www.saucedemo.com/", \
        f"Unexpectedly remained on login page: {driver.current_url}"
