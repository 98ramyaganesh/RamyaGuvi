@pytest.fixture(scope="module")
def driver():
    # Path to your ChromeDriver (update this path if needed)
    service = Service("path/to/chromedriver")
    driver = webdriver.Chrome(service=service)
    driver.get("https://www.saucedemo.com/")
    yield driver
    driver.quit()

def test_title_positive(driver):
    """Positive test case: Title should be 'Swag Labs'"""
    assert driver.title == "Swag Labs", f"Expected title 'Swag Labs' but got {driver.title}"

def test_title_negative(driver):
    """Negative test case: Title should not be 'Sauce Demo'"""
    assert driver.title != "Sauce Demo", f"Unexpected title found: {driver.title}"

