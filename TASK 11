1.PYTHON SELENIUM FOR GUVI URL:
from selenium import webdriver
from selenium.webdriver.common.by import By
from selenium.webdriver.chrome.service import Service
import time

# Path to your ChromeDriver (update this path if needed)
service = Service("path/to/chromedriver")
driver = webdriver.Chrome(service=service)

# Open GUVI homepage
driver.get("https://www.guvi.in/")

# Maximize window
driver.maximize_window()

# Click on the "Sign In" button (top right)
driver.find_element(By.LINK_TEXT, "Sign In").click()

time.sleep(2)  # wait for sign-in page to load

# Enter email/username
driver.find_element(By.ID, "email").send_keys("your_email@example.com")

# Enter password
driver.find_element(By.ID, "password").send_keys("your_password")

# Click on login button
driver.find_element(By.ID, "login").click()

time.sleep(3)  # wait for redirect

# Print current URL after login
print("Current URL after login:", driver.current_url)

# Close browser
driver.quit()

