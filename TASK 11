import pytest
from selenium import webdriver
from selenium.webdriver.common.by import By
from selenium.webdriver.chrome.service import Service
import time

@pytest.fixture(scope="module")
def driver():
    # Path to your ChromeDriver (update this path if needed)
    service = Service("path/to/chromedriver")
    driver = webdriver.Chrome(service=service)
    driver.maximize_window()
    yield driver
    driver.quit()

def test_login_positive(driver):
    """Positive test case: Login with valid credentials"""
    driver.get("https://www.guvi.in/sign-in")
    driver.find_element(By.ID, "email").send_keys("your_valid_email@example.com")
    driver.find_element(By.ID, "password").send_keys("your_valid_password")
    driver.find_element(By.ID, "login").click()
    time.sleep(3)

    # Assert dashboard URL after successful login
    assert driver.current_url == "https://www.guvi.in/dashboard", \
        f"Expected dashboard URL but got {driver.current_url}"

def test_login_negative(driver):
    """Negative test case: Login with invalid credentials"""
    driver.get("https://www.guvi.in/sign-in")
    driver.find_element(By.ID, "email").send_keys("invalid_user@example.com")
    driver.find_element(By.ID, "password").send_keys("wrong_password")
    driver.find_element(By.ID, "login").click()
    time.sleep(3)

    # Assert that login fails and URL is still sign-in page
    assert driver.current_url == "https://www.guvi.in/sign-in", \
        f"Expected to remain on sign-in page but got {driver.current_url}"
