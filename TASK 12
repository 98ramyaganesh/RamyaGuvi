import pytest
from pages.nav_page import NavPage

class TestGuviNav:

    def test_courses_link_exists(self, driver):
        nav_page = NavPage(driver)
        assert nav_page.get_courses_link() is not None

    def test_parent_element(self, driver):
        nav_page = NavPage(driver)
        parent = nav_page.get_parent_li()
        assert parent.tag_name == "li"

    def test_ancestor_element(self, driver):
        nav_page = NavPage(driver)
        ancestor = nav_page.get_ancestor_ul()
        assert ancestor.tag_name == "ul"

    def test_following_sibling(self, driver):
        nav_page = NavPage(driver)
        sibling = nav_page.get_following_sibling()
        assert sibling.tag_name == "li"

    def test_preceding_sibling(self, driver):
        nav_page = NavPage(driver)
        sibling = nav_page.get_preceding_sibling()
        assert sibling.tag_name == "li"
