from selenium.webdriver.common.by import By
from pages.base_page import BasePage

class LoginPage(BasePage):
    USERNAME = (By.ID, "username")
    PASSWORD = (By.ID, "password")
    LOGIN_BTN = (By.ID, "loginBtn")
    ERROR_MSG = (By.ID, "errorMessage")

    def login(self, username, password):
        self.type(self.USERNAME, username)
        self.type(self.PASSWORD, password)
        self.click(self.LOGIN_BTN)

    def is_username_box_visible(self):
        return self.is_visible(self.USERNAME)

    def is_password_box_visible(self):
        return self.is_visible(self.PASSWORD)

    def is_login_button_enabled(self):
        return self.is_enabled(self.LOGIN_BTN)

    def get_error_message(self):
        try:
            return self.wait.until(EC.visibility_of_element_located(self.ERROR_MSG)).text
        except TimeoutException:
            return None
