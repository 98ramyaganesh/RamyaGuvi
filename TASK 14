import pytest
from pages.login_page import LoginPage
from pages.home_page import HomePage

class TestZenPortal:

    def test_successful_login_logout(self, driver):
        login_page = LoginPage(driver)
        home_page = HomePage(driver)

        login_page.login("validUser", "validPassword")
        assert "Dashboard" in driver.page_source

        assert home_page.is_logout_button_visible()
        home_page.logout()
        assert "Login" in driver.page_source

    def test_unsuccessful_login(self, driver):
        login_page = LoginPage(driver)

        login_page.login("invalidUser", "wrongPassword")
        error_msg = login_page.get_error_message()
        assert error_msg is not None
        assert "Invalid credentials" in error_msg

    def test_validate_username_password_boxes(self, driver):
        login_page = LoginPage(driver)

        assert login_page.is_username_box_visible()
        assert login_page.is_password_box_visible()

    def test_validate_login_button(self, driver):
        login_page = LoginPage(driver)

        assert login_page.is_login_button_enabled()

    def test_validate_logout_button(self, driver):
        login_page = LoginPage(driver)
        home_page = HomePage(driver)

        login_page.login("validUser", "validPassword")
        assert home_page.is_logout_button_visible()

