from selenium.webdriver.common.by import By
from pages.base_page import BasePage

class PopulationPage(BasePage):
    # XPath for world population counter
    POPULATION_COUNTER = (By.XPATH, "//div[@class='maincounter-number']/span")

    def get_population(self):
        return self.get_text(self.POPULATION_COUNTER)
