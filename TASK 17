import pytest
from pages.login_page import LoginPage
from pages.home_page import HomePage

def test_successful_login_logout(page):
    login_page = LoginPage(page)
    home_page = HomePage(page)

    login_page.load()
    login_page.login("validUser", "validPassword")

    # Assert logout button visible
    assert home_page.logout_button.is_visible()

    home_page.logout()
    assert page.url.endswith("/login")

def test_unsuccessful_login(page):
    login_page = LoginPage(page)
    login_page.load()
    login_page.login("invalidUser", "wrongPassword")

    assert login_page.is_error_displayed()

def test_username_input_box(page):
    login_page = LoginPage(page)
    login_page.load()
    expect(login_page.username_input).to_be_visible()
    login_page.username_input.fill("testUser")
    assert login_page.username_input.input_value() == "testUser"

def test_password_input_box(page):
    login_page = LoginPage(page)
    login_page.load()
    expect(login_page.password_input).to_be_visible()
    login_page.password_input.fill("secretPwd")
    assert login_page.password_input.input_value() == "secretPwd"

def test_submit_button(page):
    login_page = LoginPage(page)
    login_page.load()
    expect(login_page.login_button).to_be_enabled()

def test_logout_button(page):
    login_page = LoginPage(page)
    home_page = HomePage(page)

    login_page.load()
    login_page.login("validUser", "validPassword")

    expect(home_page.logout_button).to_be_visible()
    home_page.logout()
    assert page.url.endswith("/login")

