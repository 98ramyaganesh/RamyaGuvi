from selenium.webdriver.common.by import By
from pages.base_page import BasePage

class DashboardPage(BasePage):
    MENU_BTN = (By.ID, "react-burger-menu-btn")
    LOGOUT_LINK = (By.ID, "logout_sidebar_link")

    def logout(self):
        self.driver.find_element(*self.MENU_BTN).click()
        self.driver.find_element(*self.LOGOUT_LINK).click()

4.Allure
import allure
from behave import given, when, then
from pages.login_page import LoginPage
from pages.dashboard_page import DashboardPage

@given("I am on the Zen portal login page")
def step_impl(context):
    context.driver.get("https://www.saucedemo.com/")  # replace with Zen portal URL
    context.login_page = LoginPage(context.driver)

@when('I login with username "{username}" and password "{password}"')
def step_impl(context, username, password):
    with allure.step("Entering credentials"):
        context.login_page.login(username, password)
    context.dashboard_page = DashboardPage(context.driver)

@then("I should see the dashboard page")
def step_impl(context):
    with allure.step("Verifying dashboard"):
        assert "inventory" in context.driver.current_url

@then("I should see an error message")
def step_impl(context):
    with allure.step("Verifying error message"):
        assert "Epic sadface" in context.login_page.get_error_message()

@then("the username input box should be visible")
def step_impl(context):
    with allure.step("Checking username box"):
        assert context.login_page.is_username_box_present()

@then("the password input box should be visible")
def step_impl(context):
    with allure.step("Checking password box"):
        assert context.login_page.is_password_box_present()

@then("the submit button should be visible")
def step_impl(context):
    with allure.step("Checking submit button"):
        assert context.login_page.is_submit_button_present()

@given("I am logged into the Zen portal")
def step_impl(context):
    context.driver.get("https://www.saucedemo.com/")
    context.login_page = LoginPage(context.driver)
    context.login_page.login("standard_user", "secret_sauce")
    context.dashboard_page = DashboardPage(context.driver)

@when("I click the logout button")
def step_impl(context):
    with allure.step("Clicking logout"):
        context.dashboard_page.logout()

@then("I should be redirected to the login page")
def step_impl(context):
    with allure.step("Verifying logout redirection"):
        assert "login" in context.driver.page_source
